APP_NAME=rtaps-streaming-backend
HOST=0.0.0.0
PORT=8000

# Feature window — must match ML Algorithm/scripts/lib/config.py
WINDOW_LEN_S=10.0
STRIDE_S=1.0
BASELINE_DURATION_S=60.0
MIN_CONFIDENCE=0.6
BLINK_TRACKING_LOSS_S=2.0

# Local model file (predictions are computed in-process by default).
MODEL_PATH=../ML Algorithm/models/v1_hgb_weak.joblib

# Optional: forward features to a remote inference service instead of using
# the local model. When unset, the backend predicts locally.
FARGATE_INFERENCE_URL=
API_TOKEN=
MODEL_TIMEOUT_SEC=5.0

# Optional: where to forward predictions (e.g. RTAPS frontend webhook).
# When unset, predictions are only available via /session/{stream_id}/latest_prediction
# and the SSE stream at /session/{stream_id}/predictions/stream.

# Comma-separated browser origins (RTAPS CRA dev server: http://localhost:3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
